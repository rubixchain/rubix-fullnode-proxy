# URL of the upstream Rubix Fullnode API
FULLNODE_URL=http://localhost:20000

# Port on which the proxy service will listen
PROXY_PORT=8080

# Bind address — 127.0.0.1 ensures only nginx (on the same VM) can reach the proxy.
# Set to 0.0.0.0 only for local development without nginx.
PROXY_BIND_ADDR=127.0.0.1

# Shared secret key used to authenticate client requests.
# Clients must pass this exact key in the X-API-KEY request header.
# IMPORTANT: Generate a strong, random, and secure key for production deployment.
PROXY_SECRET_KEY=change-this-to-a-secure-secret-key-in-production

# Rate limiting (per client IP)
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_BURST=10
